# noob-cli runtime defaults. Auto-loaded by docker compose (so by ./dev.sh too).
# These make `./dev.sh` plug-and-play: the dock and truecolor colors are on out
# of the box, with no manual setup. Change a value here to change the default, or
# override for one run from your shell, e.g. `NOOB_DOCK=0 ./dev.sh`.
#
# This file is only the interactive UX toggles. Secrets (model base URL, API key,
# model name) are NOT here: those live in the mounted config at config/.env
# (copy config/.env.example). Precedence for the toggles below:
# shell export  >  this .env  >  the default written in compose.yml.

# Persistent-input dock: live input during streaming, message queue, double-ESC
# to cancel a running turn. 1 = on (default), 0 = classic per-prompt editor.
NOOB_DOCK=1

# Raw-mode line editor. 1 = on (default), 0 = plain cooked reader (an escape
# hatch if a terminal misbehaves in raw mode).
NOOB_RAW=1

# Terminal color capability advertised to the container. Docker does not forward
# COLORTERM, so without this noob falls back to 16-color and the theme degrades
# (white-looking prompt marker, white-and-green scanner instead of a green fade).
# truecolor renders the greens as designed.
COLORTERM=truecolor
