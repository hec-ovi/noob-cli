# build caches (docker bind mounts, user-owned)
/target
/.cargo-home
/workspace/

# real config lives here when the repo checkout is used as the /config mount;
# only the example and the contract are committed
/config/*
!/config/.env.example
!/config/contract.md
!/config/mcp.websearch.example.json
!/config/skills/
!/config/skills/web-search/
!/config/skills/web-search/SKILL.md
