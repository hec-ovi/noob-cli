# noob configuration. Copy to .env in this directory (the /config bind mount).
#
# Provider settings in this file are re-read for every model request. CLI flags
# and explicitly exported non-secret settings take precedence. Startup-only
# settings such as context and child-agent budgets need a new noob process.
#
# NOOB_API_KEY is read directly from this file and is not exported into the
# process environment. Protect the mounted config directory with normal file
# permissions, because tools running inside the container can access mounts.
#
# With nothing set, noob probes common local endpoints (llama.cpp
# :8090/:8080, Ollama :11434, LM Studio :1234, vLLM :8000) and uses the
# first that answers, so an empty config still lands in a working chat.

# Where the model lives (OpenAI-compatible /v1 base URL). Leave this commented
# to probe the loopback endpoints listed above.
#NOOB_BASE_URL=http://localhost:8090/v1

# Disable loopback probing for deterministic automation or shared hosts.
#NOOB_AUTODETECT=0

# API key, if the endpoint wants one. Local servers usually accept anything.
#NOOB_API_KEY=noauth

# Model name as the endpoint knows it.
#NOOB_MODEL=qwen3.6-35b-a3b

# Wire shape: chat | responses. Default: responses for api.openai.com,
# chat for everything else. Leave unset unless you know better.
#NOOB_API_STYLE=chat

# Context window in tokens; compaction starts at 75% of this.
#NOOB_CTX=131072

# Sandbox override: container (unrestricted tools) | workspace (write/edit
# stay inside the project tree). Default: container when /.dockerenv exists,
# workspace otherwise.
#NOOB_SANDBOX=container

# Sub-agent caps (P6).
#NOOB_TASK_CONCURRENCY=4
#NOOB_TASK_MAX_TURNS=25
#NOOB_TASK_WALL_CLOCK_S=300

# Not a key, a neighbor: global skills live in skills/ next to this file
# (each one is skills/<name>/SKILL.md). Project skills in .noob/skills/,
# .claude/skills/, or .agents/skills/ take priority on name clashes.
