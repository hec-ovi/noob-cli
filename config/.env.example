# noob configuration. Copy to .env in this directory (the /config bind mount).
#
# noob re-reads this file on EVERY request: edit a key here and the next call
# picks it up, no container restart. Keys never enter the process environment,
# so shell commands and child agents cannot read them.
#
# Endpoint autodetect lands in P2: with nothing set, noob will then probe
# common local endpoints (llama.cpp :8090/:8080, Ollama :11434, LM Studio
# :1234, vLLM :8000) and use the first that answers. Until then,
# NOOB_BASE_URL is required.

# Where the model lives (OpenAI-compatible /v1 base URL).
NOOB_BASE_URL=http://localhost:8090/v1

# API key, if the endpoint wants one. Local servers usually accept anything.
#NOOB_API_KEY=noauth

# Model name as the endpoint knows it.
#NOOB_MODEL=qwen3.6-35b-a3b

# Wire shape: chat | responses. Default: responses for api.openai.com,
# chat for everything else. Leave unset unless you know better.
#NOOB_API_STYLE=chat

# Context window in tokens; compaction starts at 75% of this.
#NOOB_CTX=131072

# Sub-agent caps.
#NOOB_TASK_CONCURRENCY=4
#NOOB_TASK_MAX_TURNS=25
